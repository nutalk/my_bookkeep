<view class="container">
  <view class="text-white" style="font-size:36rpx;font-weight:bold;margin-bottom:30rpx;">统计分析</view>

  <view class="row" style="gap:16rpx;margin-bottom:30rpx;">
    <view class="btn {{activeTab === 'prediction' ? 'btn-primary' : ''}}" style="width:auto;padding:16rpx 30rpx;font-size:24rpx;" bindtap="switchTab" data-tab="prediction">现金流预测</view>
    <view class="btn {{activeTab === 'history' ? 'btn-primary' : ''}}" style="width:auto;padding:16rpx 30rpx;font-size:24rpx;" bindtap="switchTab" data-tab="history">月度快照</view>
  </view>

  <!-- Prediction Tab -->
  <block wx:if="{{activeTab === 'prediction'}}">
    <view class="form-group">
      <view class="form-label">预测月数</view>
      <picker mode="selector" range="{{['6 个月', '12 个月', '24 个月', '36 个月']}}" bindchange="onMonthsChange">
        <view class="form-picker">{{predictionMonths}} 个月</view>
      </picker>
    </view>

    <view wx:if="{{loading}}" class="text-muted" style="text-align:center;padding:80rpx 0;">加载中...</view>

    <block wx:elif="{{prediction}}">
      <view class="grid-2">
        <view class="card">
          <view class="card-title">当前净值</view>
          <view class="card-value text-blue">{{formatMoney(prediction.summary.startNetWorth)}}</view>
        </view>
        <view class="card">
          <view class="card-title">{{predictionMonths}}月后预测</view>
          <view class="card-value text-green">{{formatMoney(prediction.summary.endNetWorth)}}</view>
        </view>
      </view>
      <view class="card">
        <view class="card-title">月均现金流</view>
        <view class="card-value {{prediction.summary.averageMonthlyCashFlow >= 0 ? 'text-green' : 'text-red'}}">
          {{formatMoney(prediction.summary.averageMonthlyCashFlow)}}
        </view>
      </view>

      <view wx:for="{{prediction.months}}" wx:key="month" class="card">
        <view class="row-between">
          <view class="text-white" style="font-size:28rpx;">{{item.month}}</view>
          <view class="{{item.cashFlow >= 0 ? 'text-green' : 'text-red'}}" style="font-size:28rpx;">
            {{formatMoney(item.cashFlow)}}
          </view>
        </view>
        <view class="row" style="margin-top:12rpx;gap:20rpx;">
          <view class="text-muted" style="font-size:22rpx;">资产: <text class="text-green">{{formatMoney(item.totalAssets)}}</text></view>
          <view class="text-muted" style="font-size:22rpx;">负债: <text class="text-red">{{formatMoney(item.totalLiabilities)}}</text></view>
          <view class="text-muted" style="font-size:22rpx;">净值: <text class="text-blue">{{formatMoney(item.netWorth)}}</text></view>
        </view>
      </view>
    </block>
  </block>

  <!-- History Tab -->
  <block wx:if="{{activeTab === 'history'}}">
    <view class="btn btn-primary" style="margin-bottom:30rpx;" bindtap="generateSnapshot">生成本月快照</view>

    <view wx:if="{{loading}}" class="text-muted" style="text-align:center;padding:80rpx 0;">加载中...</view>

    <block wx:elif>
      <view wx:for="{{snapshots}}" wx:key="month" class="card">
        <view class="row-between">
          <view class="text-white" style="font-size:28rpx;">{{item.month}}</view>
          <view class="{{item.monthlyCashFlow >= 0 ? 'text-green' : 'text-red'}}" style="font-size:28rpx;">
            {{formatMoney(item.monthlyCashFlow)}}
          </view>
        </view>
        <view class="row" style="margin-top:12rpx;gap:20rpx;">
          <view class="text-muted" style="font-size:22rpx;">资产: <text class="text-green">{{formatMoney(item.totalAssets)}}</text></view>
          <view class="text-muted" style="font-size:22rpx;">负债: <text class="text-red">{{formatMoney(item.totalLiabilities)}}</text></view>
          <view class="text-muted" style="font-size:22rpx;">净值: <text class="text-blue">{{formatMoney(item.netWorth)}}</text></view>
        </view>
      </view>

      <view wx:if="{{snapshots.length === 0}}" class="text-muted" style="text-align:center;padding:80rpx 0;font-size:28rpx;">暂无月度快照</view>
    </block>
  </block>
</view>
