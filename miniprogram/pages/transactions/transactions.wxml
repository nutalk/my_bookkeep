<view class="container">
  <view class="row-between" style="margin-bottom:30rpx;">
    <view class="text-white" style="font-size:36rpx;font-weight:bold;">账目记录</view>
    <view class="btn btn-success" style="width:auto;padding:16rpx 30rpx;" bindtap="toggleForm">
      {{showForm ? '收起' : '+ 记一笔'}}
    </view>
  </view>

  <view wx:if="{{showForm}}" class="card">
    <view class="form-group">
      <view class="form-label">类型</view>
      <picker mode="selector" range="{{txTypes}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="form-picker">{{txTypes[typeIndex].label}}</view>
      </picker>
    </view>
    <view class="form-group">
      <view class="form-label">金额 (元)</view>
      <input class="form-input" type="digit" value="{{form.amount}}" bindinput="onAmountInput" />
    </view>
    <view class="form-group">
      <view class="form-label">描述</view>
      <input class="form-input" placeholder="账目描述" value="{{form.description}}" bindinput="onDescInput" />
    </view>
    <view class="form-group">
      <view class="form-label">日期</view>
      <picker mode="date" value="{{form.transactionDate}}" bindchange="onDateChange">
        <view class="form-picker">{{form.transactionDate}}</view>
      </picker>
    </view>
    <view class="btn btn-success" bindtap="submitForm">记录账目</view>
  </view>

  <view wx:if="{{loading}}" class="text-muted" style="text-align:center;padding:80rpx 0;">加载中...</view>

  <block wx:elif>
    <view wx:for="{{transactions}}" wx:key="id" class="card">
      <view class="row-between">
        <view>
          <view class="text-white" style="font-size:28rpx;">{{item.description}}</view>
          <view class="row" style="margin-top:8rpx;">
            <view class="tag">{{getTypeLabel(item.type)}}</view>
            <view class="text-muted" style="font-size:22rpx;margin-left:12rpx;">{{formatDate(item.transactionDate)}}</view>
            <view wx:if="{{item.isAutoGenerated}}" class="tag" style="margin-left:8rpx;">自动</view>
          </view>
        </view>
        <view style="text-align:right;">
          <view class="{{getAmountClass(item.type)}}" style="font-size:32rpx;">
            {{['income', 'asset_income'].includes(item.type) ? '+' : ''}}{{formatMoney(item.amount)}}
          </view>
          <view wx:if="{{!item.isAutoGenerated}}" class="text-red" style="font-size:22rpx;margin-top:8rpx;" bindtap="deleteTransaction" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>

    <view wx:if="{{transactions.length === 0}}" class="text-muted" style="text-align:center;padding:80rpx 0;font-size:28rpx;">暂无账目记录</view>
  </block>
</view>
